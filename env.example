# ContractLens Environment Variables
# ===================================
# Copy this file to .env and fill in your values.
#   cp env.example .env
# NEVER commit .env to version control.

# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://contractlens:contractlens@localhost:5432/contractlens"
REDIS_URL="redis://localhost:6379/0"

# ── API Auth ───────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY="change-me-to-a-random-secret-at-least-32-bytes"

# ── LLM Providers ──────────────────────────────────────────────────────────────
# OpenRouter: https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-your-key-here"

# Groq: https://console.groq.com/keys
GROQ_API_KEY="gsk_your-groq-api-key"

# ── Observability (Langfuse) ───────────────────────────────────────────────────
# https://cloud.langfuse.com — or self-hosted LANGFUSE_HOST
LANGFUSE_PUBLIC_KEY="pk-lf-your-public-key"
LANGFUSE_SECRET_KEY="sk-lf-your-secret-key"
# LANGFUSE_HOST="https://cloud.langfuse.com"  # optional, defaults to cloud

# ── Integrations ───────────────────────────────────────────────────────────────
# Linear: https://linear.app/settings/api
LINEAR_API_KEY="lin_api_your-linear-api-key"

# SendGrid: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY="SG.your-sendgrid-api-key"

# ── Logging ────────────────────────────────────────────────────────────────────
LOG_LEVEL="INFO"                         # DEBUG | INFO | WARNING | ERROR
